# Kizashi 環境変数テンプレート
# 実際の値は .env にコピーして使う (.env は git 管理外)

# Phase 2 (Sonnet 抽出) で使用。Phase 1 収集だけなら未設定でOK。
ANTHROPIC_API_KEY=

# Qiita 公開APIのレート緩和 (任意。無くても動くが 60→1000 req/h に)。
QIITA_TOKEN=

# X (Twitter) 収集に必要。API有料(Basic $100/月〜)。未設定ならXはスキップ。
X_BEARER_TOKEN=

# LINE ダイジェスト配信 (kizashi-digest) で使用。
# LINE Developers > Messaging APIチャネル > 長期のチャネルアクセストークン。
LINE_CHANNEL_ACCESS_TOKEN=
# 自分の userId (bot を友だち追加後に取得)。push 送信先。
LINE_USER_ID=

# Reddit Data API 承認後に設定 (それまでは公開RSS hot.rss で暫定収集)。
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Phase 3 (メール配信) で使用予定。
RESEND_API_KEY=

# --- 夜間ジョブ (kizashi-night) の枠制御。すべて任意 ---
# Claude Code サブスク枠の5時間上限トークン数。未設定なら「自分の過去ピーク枠」から
# 自動キャリブレーション(=控えめ/安全側)。もっと攻めて使い切りたいなら実上限を入れる。
CLAUDE_5H_TOKEN_BUDGET=
# 週次上限トークン数。設定すると weekly 85% で夜間ジョブを止める(昼の対話を守る)。
CLAUDE_WEEKLY_TOKEN_BUDGET=

# 夜間ジョブの実行コメントを流す Discord チャンネルの Webhook URL(任意)。
# Discord > チャンネル設定 > 連携サービス > Webフック で作成し URL を貼るだけ(ボット不要)。
# 未設定なら run.log のみ。設定すると開始/週次解析/新ソース候補/進捗/終了を投稿する。
DISCORD_WEBHOOK_URL=
